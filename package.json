{
  "name": "beijing-infinite-loop",
  "version": "1.0.0",
  "description": "Beijing Infinite Loop — a deterministic first-person drive through a procedural Beijing-inspired city.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "22.23.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "generate:about": "node scripts/generate-about.mjs",
    "check:about": "node scripts/generate-about.mjs --check",
    "verify:about-generator": "node --test scripts/generate-about.test.mjs",
    "generate:poe2-redirects": "node scripts/generate-poe2-redirects.mjs",
    "verify": "npm run verify:static && npm run verify:ci && npm run verify:performance-telemetry && npm run verify:geometry && npm run typecheck",
    "verify:static": "npm run check:about && npm run verify:about-generator && node scripts/verify-static.mjs",
    "verify:ci": "node scripts/verify-ci.mjs",
    "verify:performance-telemetry": "node --test scripts/performance-telemetry.test.mjs",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify:geometry": "node scripts/geometry-check.mjs",
    "verify:browser": "node scripts/verify.mjs",
    "verify:seam": "node scripts/seam-check.mjs",
    "verify:performance": "node scripts/performance-check.mjs",
    "verify:bundle": "node scripts/bundle-budget.mjs"
  },
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/three": "0.185.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "7.3.6"
  }
}
