{
  "name": "beijing-infinite-loop",
  "version": "1.0.0",
  "description": "Beijing Infinite Loop — a deterministic first-person drive through a procedural Beijing-inspired city.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify": "npm run verify:geometry && npm run typecheck",
    "verify:geometry": "node scripts/geometry-check.mjs",
    "verify:browser": "node scripts/verify.mjs",
    "verify:seam": "node scripts/seam-check.mjs",
    "verify:performance": "node scripts/performance-check.mjs",
    "verify:bundle": "node scripts/bundle-budget.mjs"
  },
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/three": "0.185.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "6.4.3"
  }
}
